<Window x:Class="DiskHealthAdvisor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Disk Health Advisor"
        WindowStyle="None"
        ResizeMode="CanResize"
        MinHeight="720"
        MinWidth="1120"
        Height="780"
        Width="1240"
        Background="#101418"
        Foreground="#E7EDF3"
        FontFamily="Segoe UI"
        Icon="Resources/DiskHealthAdvisor.ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="7"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171D24"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#1E2630"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2E3845"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9BA8B6"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#5E9EFF"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#253142"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="BorderBrush" Value="#405068"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2F4056"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#5E9EFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E2A38"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4D86DC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#171D24"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2E3845"/>
                                <Setter Property="Foreground" Value="#6F7C8B"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C7D2DF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#243040"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1B2532"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D94B4B"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InvisibleScrollButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder"
                                Background="#657286"
                                CornerRadius="4"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#8CA0BA"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#5E9EFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#202A35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource InvisibleScrollButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource InvisibleScrollButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="10"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="PART_Track" Property="Orientation" Value="Horizontal"/>
                                <Setter TargetName="Root" Property="MinHeight" Value="10"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="10"/>
                                <Setter Property="Height" Value="Auto"/>
                                <Setter TargetName="Root" Property="MinWidth" Value="10"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#10161D"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="BorderBrush" Value="#405068"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#10161D"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="BorderBrush" Value="#405068"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="6"
                                                Padding="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  RecognizesAccessKey="True"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                      Width="8"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#5E9EFF"/>
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#17202A"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#5E9EFF"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#171D24"/>
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#2E3845"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade"
                                   MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="#10161D"
                                        BorderBrush="#5E9EFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="2"
                                        MaxHeight="260">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F7C8B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#10161D"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#253142"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#24405F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F7C8B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="Background" Value="#1B232D"/>
            <Setter Property="BorderBrush" Value="#2E3845"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Margin="0,0,6,0" SnapsToDevicePixels="True">
                            <Border x:Name="TabBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True"/>
                                    <Border x:Name="SelectedLine"
                                            Height="3"
                                            Background="Transparent"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Stretch"
                                            CornerRadius="0,0,4,4"
                                            Margin="0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#253142"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#5E9EFF"/>
                                <Setter TargetName="SelectedLine" Property="Background" Value="#5E9EFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#243041"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#66717F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#141A21"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="RowBackground" Value="#141A21"/>
            <Setter Property="AlternatingRowBackground" Value="#19212A"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E3845"/>
            <Setter Property="BorderBrush" Value="#2E3845"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#253142"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="BorderBrush" Value="#405068"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#141A21"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#24405F"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F2B38"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E7EDF3"/>
            <Setter Property="BorderBrush" Value="#2E3845"/>
            <Setter Property="Padding" Value="6,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#24405F"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar"
                Grid.Row="0"
                Height="36"
                Background="#0D1116"
                BorderBrush="#243040"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image Source="Resources/DiskHealthAdvisor.png" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="Disk Health Advisor" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="Read-only" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,1,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE713;"
                            ToolTip="Настройки"
                            Click="OpenSettings_Click"/>
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE921;"
                            ToolTip="Свернуть"
                            Click="MinimizeWindow_Click"/>
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Content="&#xE922;"
                            ToolTip="Развернуть"
                            Click="ToggleMaximizeWindow_Click"/>
                    <Button Style="{StaticResource CloseTitleBarButtonStyle}"
                            Content="&#xE8BB;"
                            ToolTip="Закрыть в трей"
                            Click="CloseWindow_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="ThemeArtworkLayer"
              Grid.RowSpan="3"
              Panel.ZIndex="-1"
              IsHitTestVisible="False"
              ClipToBounds="True"
              Opacity="0.9"/>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Image Source="Resources/DiskHealthAdvisor.png"
                       Width="42"
                       Height="42"
                       Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Disk Health Advisor" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Read-only диагностика дисков человеческим языком" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource TopActionButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Margin="0,0,8,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="Обновить"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportReportCommand}" Style="{StaticResource TopActionButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE74E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Margin="0,0,8,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="Сохранить отчёт"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding CopyShortReportCommand}" Style="{StaticResource TopActionButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Margin="0,0,8,0"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="Кратко"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1" SelectedIndex="0">
            <TabItem Header="Состояние">
                <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Физические диски" FontWeight="SemiBold" Margin="16,14,16,10"/>
                    <ListBox ItemsSource="{Binding Disks}"
                             SelectedItem="{Binding SelectedDisk}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E7EDF3"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Margin="8,4" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Model, TargetNullValue=Нет данных}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding MediaTypeDisplay}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding BusType, TargetNullValue=Нет данных}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Border Background="{Binding HealthBadgeBrush}" CornerRadius="4" Padding="7,3" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding HealthBadge}" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding UserProfile}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{Binding LevelBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding LevelText}" FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedReport.Summary}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Важные изменения" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding ImportantChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Профиль и мастер диагностики" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="Роль диска" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ComboBox ItemsSource="{Binding DiskProfileOptions}"
                                              SelectedItem="{Binding SelectedDiskProfile}"
                                              Background="#10161D"
                                              Foreground="#E7EDF3"
                                              BorderBrush="#405068"
                                              Padding="8,5"/>
                                </DockPanel>
                                <TextBlock Text="{Binding DiagnosticWizardText}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDisk.Model, TargetNullValue=Диск не выбран}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding DiskDetails}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,10,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding DataWarnings}" Margin="0,0,0,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#242B21" BorderBrush="#6C7A45" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Почему часть данных пустая" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TabControl SelectedIndex="0">
                        <TabItem Header="Диагноз">
                            <StackPanel Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding RiskCategories}" Margin="0,0,0,12">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                    <TextBlock Text="{Binding Status}" Foreground="{Binding Brush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="Скопировать краткий отчёт" Command="{Binding CopyShortReportCommand}" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding ExpertModeText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Главные причины" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding SelectedReport.Reasons}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Что сделать" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding SelectedReport.Recommendations}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Причины">
                            <DataGrid ItemsSource="{Binding SelectedReport.Details}" AutoGenerateColumns="False" Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Параметр" Binding="{Binding Name}" Width="220"/>
                                    <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Ресурс SSD">
                            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SsdResource.Message}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <UniformGrid Columns="2">
                                        <TextBlock Text="Заявленный TBW" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Text="{Binding SsdResource.DeclaredTbwText}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Уже записано" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Text="{Binding SsdResource.TotalBytesWrittenText}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Использовано" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Text="{Binding SsdResource.UsedPercentText}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Средняя запись в день" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Text="{Binding SsdResource.AverageWrittenText}" Margin="0,0,0,8"/>
                                        <TextBlock Text="Ориентир достижения TBW" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,12,8"/>
                                        <TextBlock Text="{Binding SsdResource.EstimatedTbwDateText}" Margin="0,0,0,8"/>
                                    </UniformGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <TextBox Width="160" Text="{Binding ManualTbwText, UpdateSourceTrigger=PropertyChanged}" ToolTip="TBW в терабайтах"/>
                                        <Button Content="Добавить TBW вручную" Command="{Binding AddTbwCommand}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Поиск TBW в интернете" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding OnlineTbwQuery, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Можно оставить пустым: будет использована модель выбранного диска"/>
                                                <Button Grid.Column="1"
                                                        Content="Найти"
                                                        Command="{Binding SearchOnlineTbwCommand}"
                                                        Margin="8,0,0,0"/>
                                                <Button Grid.Column="2"
                                                        Content="Сохранить выбранное"
                                                        Command="{Binding SaveOnlineTbwCommand}"
                                                        Margin="8,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding OnlineTbwStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,8,0,10"/>
                                            <ListBox ItemsSource="{Binding OnlineTbwCandidates}"
                                                     SelectedItem="{Binding SelectedOnlineTbwCandidate}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     MaxHeight="260"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource PanelBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <DockPanel LastChildFill="True">
                                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding TbwText}" FontWeight="SemiBold" Margin="12,0,0,0"/>
                                                                    <TextBlock Text="{Binding Model}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                </DockPanel>
                                                                <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0">
                                                                    <Run Text="{Binding CapacityText, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                    <Run Text="{Binding WarrantyText, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                    <Run Text="{Binding Source, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Evidence}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
                                                                <TextBlock Text="{Binding Warning}" Foreground="#C9A227" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <TabItem Header="История">
                            <StackPanel Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding HistoryCharts}" Margin="0,0,0,12">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,3,0,8"/>
                                                    <ItemsControl ItemsSource="{Binding Points}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" Height="76" VerticalAlignment="Bottom"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="10"
                                                                        Height="{Binding Height}"
                                                                        Background="#5E9EFF"
                                                                        CornerRadius="3"
                                                                        Margin="0,0,4,0"
                                                                        VerticalAlignment="Bottom"
                                                                        ToolTip="{Binding Label}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DataGrid ItemsSource="{Binding HistoryDetails}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Показатель" Binding="{Binding Name}" Width="240"/>
                                        <DataGridTextColumn Header="Изменение" Binding="{Binding Value}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Что пишет на диск">
                            <DataGrid ItemsSource="{Binding ProcessActivities}" AutoGenerateColumns="False" Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Процесс" Binding="{Binding ProcessName}" Width="180"/>
                                    <DataGridTextColumn Header="Запись сейчас, Б/с" Binding="{Binding WrittenBytesPerSecond, TargetNullValue=Нет данных}" Width="160"/>
                                    <DataGridTextColumn Header="Чтение сейчас, Б/с" Binding="{Binding ReadBytesPerSecond, TargetNullValue=Нет данных}" Width="160"/>
                                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Сырые данные">
                            <DataGrid ItemsSource="{Binding SelectedDisk.RawAttributes}" AutoGenerateColumns="False" Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                                    <DataGridTextColumn Header="Атрибут" Binding="{Binding Name}" Width="220"/>
                                    <DataGridTextColumn Header="Raw value" Binding="{Binding RawValue, TargetNullValue=Нет данных}" Width="160"/>
                                    <DataGridTextColumn Header="Normalized" Binding="{Binding NormalizedValue, TargetNullValue=Нет данных}" Width="120"/>
                                    <DataGridTextColumn Header="Threshold" Binding="{Binding Threshold, TargetNullValue=Нет данных}" Width="120"/>
                                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Настройки" Visibility="Collapsed">
                            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Путь к smartctl.exe" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Выбрать" Command="{Binding PickSmartCtlCommand}" Margin="8,0,0,0"/>
                                        <TextBox Text="{Binding SmartCtlPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding SmartCtlStatus}" Foreground="#DDE9A6" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Установить smartctl" Command="{Binding InstallSmartCtlCommand}"/>
                                    </StackPanel>
                                    <Border Background="#111820" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Тема оформления" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                                      SelectedItem="{Binding SelectedTheme}"
                                                      Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding ThemeNoticeText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                            <CheckBox Content="Режим опытного пользователя"
                                                      IsChecked="{Binding ExpertMode}"
                                                      Foreground="#E7EDF3"
                                                      Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding ExpertModeText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="Для NVMe/M.2 Windows часто не отдаёт температуру, percentage_used, data_units_written и unsafe_shutdowns. smartctl читает эти данные через read-only запросы и не меняет диск." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                    <TextBlock Text="Если smartmontools уже установлен, приложение попробует найти smartctl.exe само: рядом с программой, в Program Files и в PATH." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    <TextBlock Text="Часть данных может быть недоступна без прав администратора." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <TabItem Header="Справка">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding KnowledgeBase}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding Details}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="День диска">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding MonitoringButtonText}"
                                    Command="{Binding ToggleMonitoringCommand}"
                                    MinWidth="170"
                                    Margin="12,0,0,0"/>
                            <StackPanel>
                                <TextBlock Text="Наблюдение за дисками" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding MonitorStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Сводка дня" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Общий вывод строится по сегодняшним событиям, свежей диагностике дисков, температуре и всплескам записи процессов."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding DiskDaySummary}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,10,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Row="4" ItemsSource="{Binding MonitorEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding TimeText}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding DateText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Left" Background="{Binding SeverityBrush}" Width="4" CornerRadius="2" Margin="0,1,8,1"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding DiskModel}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="12,3,0,0"/>
                                                <TextBlock Text="{Binding Details}" TextWrapping="Wrap" Margin="12,7,0,0"/>
                                                <TextBlock Text="{Binding PossibleCause}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="12,6,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Температура" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding TemperatureText}" Margin="0,2,0,8"/>
                                                <TextBlock Text="Запись" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                <TextBlock Text="{Binding WriteRateText}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Обслуживание">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,12,0,0">
                    <StackPanel>
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Центр обслуживания"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Безопасные действия для дисков и Windows. Приложение ничего не удаляет само: оно открывает штатные инструменты или копирует команды/чеклисты."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,12"/>
                                <ItemsControl ItemsSource="{Binding MaintenanceSummary}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelAltBrush}"
                                                    BorderBrush="#2E3845"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,0,10,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding MaintenanceActions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelBrush}"
                                            BorderBrush="#2E3845"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,12,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding AccentBrush}"
                                                    CornerRadius="2"/>
                                            <StackPanel Grid.Column="2">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Right"
                                                            Background="{Binding AccentBrush}"
                                                            CornerRadius="4"
                                                            Padding="7,3"
                                                            Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding Category}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Status}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                                <TextBlock Text="{Binding Details}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,7,0,0"/>
                                                <Border Background="#111820"
                                                        BorderBrush="#2E3845"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        Padding="9"
                                                        Margin="0,10,0,0">
                                                    <TextBlock Text="{Binding Safety}"
                                                               Foreground="#DDE9A6"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                                <Button Content="{Binding ButtonText}"
                                                        Command="{Binding DataContext.RunMaintenanceActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,12,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAction}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Расследование">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="380"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12">
                                    <Grid>
                                        <TextBlock Text="Пока всё спокойно. Явных проблем по текущим данным не найдено, расследование не требуется."
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="8,38,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Investigations.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="Активные расследования" FontWeight="SemiBold" Margin="4,0,4,10"/>
                                        <ListBox ItemsSource="{Binding Investigations}"
                                                 SelectedItem="{Binding SelectedInvestigation}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#E7EDF3"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding SimpleTitle}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding DiskModel}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding TriggerMetricText}" Foreground="#BFD8FF" Margin="0,6,0,0" TextWrapping="Wrap" MaxHeight="38"/>
                                                            <TextBlock Text="{Binding RiskText}" Foreground="#DDE9A6" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Conclusion}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,8,0,0" MaxHeight="44"/>
                                                            <Button Content="Открыть"
                                                                    Command="{Binding DataContext.SelectInvestigationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,10,0,0"
                                                                    Padding="12,6"
                                                                    HorizontalAlignment="Left"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16">
                                    <Grid>
                                        <Border Background="#1B232D"
                                                BorderBrush="#2E3845"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="18"
                                                VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Investigations.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="Расследование не требуется" FontSize="21" FontWeight="SemiBold"/>
                                                <TextBlock Text="Сейчас программа не видит признаков перегрева, роста ошибок, нестабильных участков, критического SMART-статуса или других сценариев из базы правил."
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                                <TextBlock Text="Продолжайте периодически нажимать «Обновить». Если появится подозрительный симптом или показатель начнёт ухудшаться, здесь автоматически появится карточка расследования."
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Investigations.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedInvestigation.SimpleTitle, TargetNullValue=Расследование не выбрано}" FontSize="21" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding SelectedInvestigation.DiskSummary}" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                            <UniformGrid Columns="3" Margin="0,12,0,14">
                                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Статус" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                        <TextBlock Text="{Binding SelectedInvestigation.StatusText}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,10,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Уровень опасности" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                        <TextBlock Text="{Binding SelectedInvestigation.RiskText}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Уверенность" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                        <TextBlock Text="{Binding SelectedInvestigation.ConfidenceText}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </UniformGrid>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="О каком диске речь" FontWeight="SemiBold"/>
                                                    <ItemsControl ItemsSource="{Binding InvestigationContext}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,6">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="150"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Кто сейчас пишет" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding InvestigationProcessHint}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,8"/>
                                                    <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <TextBlock Text="Достаточно ли данных" FontWeight="SemiBold"/>
                                                            <ItemsControl ItemsSource="{Binding InvestigationDataReadiness}" Margin="0,8,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,0,0,6">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="150"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                    <ItemsControl ItemsSource="{Binding InvestigationTopWriters}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,0,6">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="2*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding ProcessName}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                            <TextBlock Text="{Binding Comment}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,8,0"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                            <TextBlock Text="Запись" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                                            <TextBlock Text="{Binding WrittenRateText}" TextWrapping="Wrap"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                                                            <TextBlock Text="Чтение" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                                            <TextBlock Text="{Binding ReadRateText}" TextWrapping="Wrap"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="3" Margin="8,0,0,0">
                                                                            <TextBlock Text="Если весь день" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                                            <TextBlock Text="{Binding ProjectedDailyWriteText}" TextWrapping="Wrap"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Кто писал сегодня" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding InvestigationWriteHistoryHint}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,8"/>
                                                    <ItemsControl ItemsSource="{Binding InvestigationWriteEvents}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,0,6">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="80"/>
                                                                            <ColumnDefinition Width="2*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold"/>
                                                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                            <TextBlock Text="{Binding ProcessTitle}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                            <TextBlock Text="{Binding PossibleCause}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,8,0"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                                                            <TextBlock Text="Запись" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                                            <TextBlock Text="{Binding WriteRateText}" TextWrapping="Wrap"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="3" Margin="8,0,0,0">
                                                                            <TextBlock Text="Если весь день" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                                            <TextBlock Text="{Binding ProjectedDailyWriteText}" TextWrapping="Wrap"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Что обнаружено" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SelectedInvestigation.DetectedProblem}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Почему это важно" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SelectedInvestigation.UserExplanation}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Возможные причины" FontWeight="SemiBold"/>
                                                        <ItemsControl ItemsSource="{Binding SelectedInvestigation.PossibleCauses}" Margin="0,8,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12">
                                                    <StackPanel>
                                                        <TextBlock Text="Что сделать" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding SelectedInvestigation.PrimaryActionText}" TextWrapping="Wrap" Margin="0,8,0,8" Foreground="#E7EDF3"/>
                                                        <ItemsControl ItemsSource="{Binding SelectedInvestigation.SuggestedChecks}" Margin="0,8,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Результат проверки" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SelectedInvestigation.Conclusion}" TextWrapping="Wrap" Margin="0,6,0,8"/>
                                                    <TextBlock Text="{Binding SelectedInvestigation.ConfidenceReason}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Снимок до" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                        <TextBlock Text="{Binding SelectedInvestigation.BeforeSnapshot.Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=Нет данных}" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="Снимок после" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                                                        <TextBlock Text="{Binding SelectedInvestigation.AfterSnapshot.Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm}, TargetNullValue=Ещё не выполнен}" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Background="#1B232D" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Что делать дальше" FontWeight="SemiBold"/>
                                                    <ItemsControl ItemsSource="{Binding SelectedInvestigation.NextActions}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#111820" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Отметить выполненное действие" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right" Content="Я выполнил рекомендацию" Command="{Binding MarkInvestigationActionCommand}" Margin="8,0,0,0"/>
                                                        <ComboBox ItemsSource="{Binding InvestigationActions}"
                                                                  SelectedItem="{Binding SelectedInvestigationAction}"
                                                                  Background="#10161D"
                                                                  Foreground="#E7EDF3"
                                                                  BorderBrush="#405068"
                                                                  Padding="8,5"/>
                                                    </DockPanel>
                                                    <TextBox Text="{Binding InvestigationComment, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" ToolTip="Комментарий к действию"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Повторить проверку" Command="{Binding RecheckInvestigationCommand}"/>
                                                        <Button Content="Сохранить расследование" Command="{Binding ExportInvestigationCommand}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <Expander Header="Показать технические подробности" Foreground="#E7EDF3" Background="#1B232D" BorderBrush="#2E3845" Padding="10">
                                                <StackPanel Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding SelectedInvestigation.TechnicalExplanation}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                    <ItemsControl ItemsSource="{Binding SelectedInvestigation.TechnicalDetails}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Expander>
                                        </StackPanel>
                                    </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>

            </TabItem>
        </TabControl>

        <Border x:Name="SettingsOverlay"
                Grid.RowSpan="3"
                Panel.ZIndex="25"
                Background="#D80B1015"
                CornerRadius="10"
                Visibility="Collapsed">
            <Grid>
                <Border Width="720"
                        MaxHeight="620"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource TitleBarButtonStyle}"
                                    Content="&#xE8BB;"
                                    ToolTip="Закрыть настройки"
                                    Click="CloseSettings_Click"/>
                            <StackPanel>
                                <TextBlock Text="Настройки" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="Параметры приложения, smartctl и оформление"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Путь к smartctl.exe" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Выбрать" Command="{Binding PickSmartCtlCommand}" Margin="8,0,0,0"/>
                                            <TextBox Text="{Binding SmartCtlPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding SmartCtlStatus}" Foreground="#DDE9A6" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                        <Button Content="Установить smartctl" Command="{Binding InstallSmartCtlCommand}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource PanelAltBrush}" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Тема оформления" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding ThemeOptions}"
                                                  SelectedItem="{Binding SelectedTheme}"
                                                  Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding ThemeNoticeText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                        <CheckBox Content="Режим опытного пользователя"
                                                  IsChecked="{Binding ExpertMode}"
                                                  Foreground="#E7EDF3"
                                                  Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding ExpertModeText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Для NVMe/M.2 Windows часто не отдаёт температуру, percentage_used, data_units_written и unsafe_shutdowns. smartctl читает эти данные через read-only запросы и не меняет диск."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Если smartmontools уже установлен, приложение попробует найти smartctl.exe само: рядом с программой, в Program Files и в PATH."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Часть данных может быть недоступна без прав администратора."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Panel.ZIndex="20"
                Background="#D80B1015"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Border Width="500"
                        Padding="24"
                        Background="#1B232D"
                        BorderBrush="#405068"
                        BorderThickness="1"
                        CornerRadius="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="38"
                                    Height="38"
                                    Background="#102235"
                                    BorderBrush="{Binding ThemeAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Margin="0,0,12,0">
                                <TextBlock Text="&#xE9D9;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{Binding ThemeAccentBrush}"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Сканирую диски"
                                           FontSize="23"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Windows, SMART, история и процессы"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Сканирую диски..."
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Visibility="Collapsed"/>
                        <TextBlock Text="Читаю данные Windows, SMART и историю. Это может занять несколько секунд."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,10,0,18"
                                   Visibility="Collapsed"/>
                        <TextBlock Text="Программа только читает данные. Обычно это занимает несколько секунд."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,16,0,18"/>
                        <Border Height="8"
                                Background="#10161D"
                                BorderBrush="#2E3845"
                                BorderThickness="1"
                                CornerRadius="4"
                                ClipToBounds="True">
                            <Grid>
                                <Border Background="#253142" CornerRadius="4"/>
                                <Border x:Name="ScanBeam"
                                        Width="150"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"
                                        Background="{Binding ThemeAccentBrush}"
                                        Opacity="0.95">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="-160"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="ScanBeam"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-160"
                                                             To="510"
                                                             Duration="0:0:1.35">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <UniformGrid Columns="3" Margin="0,16,0,0">
                            <Border Background="#111820" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="Диски" TextAlignment="Center" Foreground="#C7D2DF"/>
                            </Border>
                            <Border Background="#111820" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,8,0">
                                <TextBlock Text="SMART" TextAlignment="Center" Foreground="#C7D2DF"/>
                            </Border>
                            <Border Background="#111820" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="8">
                                <TextBlock Text="История" TextAlignment="Center" Foreground="#C7D2DF"/>
                            </Border>
                        </UniformGrid>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,70,8,0"
                Background="{Binding ThemeAccentSoftBrush}"
                BorderBrush="{Binding ThemeAccentBrush}"
                BorderThickness="1"
                CornerRadius="9"
                Padding="14,11">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE73E;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="{Binding ThemeAccentBrush}"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ToastMessage}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#0D1116" BorderBrush="#2E3845" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,14,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock DockPanel.Dock="Right" Text="Read-only: приложение только читает данные и строит диагностику." Foreground="{StaticResource MutedTextBrush}"/>
            </DockPanel>
        </Border>
    </Grid>
    </Grid>
</Window>

